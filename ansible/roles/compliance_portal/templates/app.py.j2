@app.route("/")
def dashboard():
    return render_template_string(DASHBOARD_HTML)


@app.route("/health")
def health():
    return jsonify({
        "status": "healthy",
        "version": APP_VERSION,
        "timestamp": datetime.utcnow().isoformat(),
        "database": f"{DB_HOST}:{DB_PORT}/{DB_NAME}",
{% if enable_mifid_reports %}
        "mifid_reports": "enabled",
{% endif %}
{% if enable_gdpr_scanner %}
        "gdpr_scanner": "enabled",
{% endif %}
{% if enable_pci_audit %}
        "pci_audit": "enabled",
{% endif %}
    })


@app.route("/api/reports")
def reports():
    return jsonify({
        "reports": [
            {"type": "MiFID II", "status": "completed", "transactions": 12481, "flagged": 3},
            {"type": "GDPR", "status": "completed", "records_scanned": 84201, "violations": 0},
            {"type": "PCI-DSS", "status": "in_progress", "progress": 67},
        ]
    })


@app.route("/api/status")
def status():
    return jsonify({
        "app": "compliance-portal",
        "version": APP_VERSION,
        "environment": "{{ app_env }}",
        "uptime": "running",
        "db_connection": f"{DB_HOST}:{DB_PORT}",
        "features": {
            "mifid": {{ enable_mifid_reports | lower }},
            "gdpr": {{ enable_gdpr_scanner | lower }},
            "pci": {{ enable_pci_audit | lower }},
        }
    })


if __name__ == "__main__":
