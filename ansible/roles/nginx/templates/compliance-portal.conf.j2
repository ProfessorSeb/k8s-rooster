server {
    listen 80;
    server_name _;

    # serve frontend
    location / {
        root /var/www/html;
        try_files $uri $uri/ /index.html;
    }

    # proxy API requests to the backend Flask app
    location /api/ {
        proxy_pass http://{{ compliance_app_host | default(hostvars[groups['appservers'][0]].ansible_host) }}:{{ compliance_app_port | default(5000) }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    access_log /var/log/nginx/compliance_access.log;
    error_log /var/log/nginx/compliance_error.log;
}
