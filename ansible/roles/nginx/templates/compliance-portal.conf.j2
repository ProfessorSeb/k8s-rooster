server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/compliance_portal_access.log;
    error_log /var/log/nginx/compliance_portal_error.log;

    location / {
        # Avoid hardcoded backend IPs; derive from inventory.
        proxy_pass http://{{ hostvars[groups['appservers'][0]].ansible_host }}:{{ flask_port | default(5000) }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
