upstream compliance_backend {
    server {{ nginx_upstream_host }}:{{ nginx_upstream_port }};
}

server {
    listen 80;
    server_name {{ app_domain | default('_') }};

    access_log {{ nginx_access_log }};
    error_log {{ nginx_error_log }};

    location / {
        proxy_pass http://compliance_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 30s;
    }

    location /health {
        proxy_pass http://compliance_backend/health;
        access_log off;
    }

    location /static/ {
        proxy_pass http://compliance_backend/static/;
        expires 1h;
        add_header Cache-Control "public, immutable";
    }
}
